NODE_ENV=development
PORT=4000

# PostgreSQL en développement comme en production (voir docker-compose.yml
# à la racine pour lancer une instance locale en une commande)
DATABASE_URL=postgres://retour:retour@localhost:5432/retour_chez_soi

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Le Retour Chez Soi <bonjour@leretourchezsoi.ca>
ADMIN_NOTIFICATION_EMAIL=admin@leretourchezsoi.ca

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback
